# Required
TELEGRAM_BOT_TOKEN=
GROQ_API_KEY=

# AI — text model
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024
MAX_HISTORY_TURNS=10

# AI — multimodal models (auto-populated with sensible defaults)
# Vision model for photo & video thumbnail analysis
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Speech-to-text model for voice messages
GROQ_WHISPER_MODEL=whisper-large-v3

# Auto-reply / takeover behavior
BOT_REPLY_DELAY_MS=3000
TAKEOVER_TTL_MS=600000

# Startup anti-replay guard (recommended ON)
DROP_PENDING_UPDATES=true
IGNORE_OLD_UPDATES_ON_START=true
OLD_UPDATE_GRACE_SECONDS=5

# Optional Google Sheets keyword + logging integration
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=Keywords
SHEETS_CACHE_TTL_MS=300000

# Telegram Mini App URL — used by /login command to send the web_app button
# Register the same URL in @BotFather → Bot Settings → Menu Button → URL
MINI_APP_URL=https://businessbot-production.up.railway.app

# Provide one of these for Google auth (prefer JSON env in Railway)
GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_SERVICE_ACCOUNT_PATH=
